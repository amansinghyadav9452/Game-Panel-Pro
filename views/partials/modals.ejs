        <div id="licenseModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>License Details</h2>

            <button id="closeModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <div class="detail">

                <span>Key</span>

                <strong id="modalKey">-</strong>

            </div>

            <div class="detail">

                <span>Status</span>

                <strong id="modalStatus">-</strong>

            </div>

            <div class="detail">

                <span>Expiry</span>

                <strong id="modalExpiry">-</strong>

            </div>

            <div class="detail">

                <span>Devices</span>

                <strong id="modalDevices">-</strong>

            </div>

            <div class="detail">

                <span>Last Device</span>

                <strong id="modalLastDevice">-</strong>

            </div>

        </div>

        <div class="modal-actions">

<button
    class="ban-btn"
    id="banLicenseBtn">

    Ban

</button>

<button
    class="extend-btn"
    id="extendLicenseBtn">

    Extend

</button>

            <button class="reset-btn" id="resetDeviceBtn">

                Reset Device

            </button>

            <button
                class="delete-btn"
                id="deleteLicenseBtn">

                Delete

            </button>
        </div>

    </div>

</div>

<div id="createKeyModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>Create License</h2>

            <button id="closeCreateModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <div class="input-group">

    <label>License Key</label>

    <input
        type="text"
        id="licenseKey"
        placeholder="Enter License Key"
        maxlength="32"
        minlength="4"
        autocomplete="off"
        required>

</div>

            <div class="input-group">

                <label>License Type</label>

                <select id="licenseType">

                    <option value="public">Public</option>

                    <option value="premium">Premium</option>

                </select>

            </div>

            <div class="input-group">

                <label>Expiry (Days)</label>

                <input
                    type="number"
                    id="expiryDays"
                    value="30">

            </div>

            <div class="input-group">

                <label>Max Devices</label>

                <input
                    type="number"
                    id="maxUses"
                    value="1">

            </div>

        </div>

        <div class="modal-actions">

            <button id="generateBtn">

                Generate License

            </button>

        </div>

    </div>

</div>

        <div id="deleteModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>Delete License</h2>

            <button id="closeDeleteModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <p style="text-align:center;font-size:17px;line-height:1.6;">

                Are you sure you want to delete this license?

                <br><br>

                <strong id="deleteLicenseKey"></strong>

            </p>

        </div>

        <div class="modal-actions">

            <button
                class="reset-btn"
                id="cancelDeleteBtn">

                Cancel

            </button>

            <button
                class="delete-btn"
                id="confirmDeleteBtn">

                Delete Forever

            </button>

        </div>

    </div>

</div>

    </main>

</div>
<div id="toast"></div>
<div id="extendModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>Extend License</h2>

            <button id="closeExtendModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <div class="input-group">

                <label>Extend Days</label>

                <input
                    type="number"
                    id="extendDays"
                    value="30"
                    min="1">

            </div>

        </div>

        <div class="modal-actions">

            <button id="saveExtendBtn">

                Extend License

            </button>

        </div>

    </div>

</div>