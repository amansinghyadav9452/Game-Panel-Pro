    <aside class="sidebar">

<div class="sidebar-profile">

<div class="profile-image-wrapper">

    <div
        class="profile-avatar"
        id="profileAvatar">

        <% if (typeof admin !== "undefined" && admin.profileImage) { %>

            <img
                src="<%= admin.profileImage %>"
                class="profile-photo"
                alt="Profile">

        <% } else { %>

            <span class="profile-letter">A</span>

        <% } %>

        <input
            type="file"
            id="profileInput"
            accept="image/*"
            hidden>

    </div>

    <div
        class="profile-menu"
        id="profileMenu">

        <button
            type="button"
            id="viewProfileBtn">

            <i class="fa-solid fa-expand"></i>

            View Profile Picture

        </button>

        <button
            type="button"
            id="updateProfileBtn">

            <i class="fa-solid fa-upload"></i>

            Update Profile Picture

        </button>

    </div>

</div>

    <button
        id="editDisplayName"
        class="profile-edit">

        <i class="fa-solid fa-pen"></i>

    </button>

    <h3 id="adminDisplayName">

        Loading...

    </h3>

    <div class="sidebar-status">

        <span class="status-dot"></span>

        <span class="admin-status-text">

            Online

        </span>

    </div>

</div>

<hr class="sidebar-divider">


        <nav>

<a href="/panel" class="<%= activePage === 'dashboard' ? 'active' : '' %>">

    <i class="fa-solid fa-house"></i>

    Dashboard

</a>

<a href="/public-keys" class="<%= activePage === 'public-keys' ? 'active' : '' %>">

    <i class="fa-solid fa-key"></i>

    Public Keys

</a>

<a href="/premium-keys"
class="<%= activePage === 'premium-keys' ? 'active' : '' %>">

    <i class="fa-solid fa-crown"></i>

    Premium Keys

</a>

<a href="/logs"
   class="<%= activePage === 'logs' ? 'active' : '' %>">

    <i class="fa-solid fa-clock-rotate-left"></i>

    Logs

</a>

<a href="/settings"
class="<%= activePage === 'settings' ? 'active' : '' %>">

    <i class="fa-solid fa-gear"></i>

    Settings

</a>

        <a href="#" id="notificationBtn">

    <i class="fa-solid fa-bell"></i>

    Notifications

</a>

<a href="#" id="sidebarLogout">

    <i class="fa-solid fa-right-from-bracket"></i>

    Logout

</a>

</nav>
<div
class="profile-viewer"
id="profileViewer">

<span
    id="closeViewer"
    class="close-viewer">

    ×

</span>

<img
    id="viewerImage"
    src=""
    alt="Profile">

</div>
    </aside>
