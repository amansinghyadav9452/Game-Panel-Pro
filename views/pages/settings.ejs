<!DOCTYPE html>
<html lang="en">

<head>

    <title>Game Panel | Settings</title>

    <%- include("../partials/head") %>

    <link rel="stylesheet" href="/css/settings.css">

</head>

<body>

<div id="overlay"></div>

<div class="layout">

    <%- include("../partials/sidebar") %>

    <main class="content">

        <section class="settings-page">

            <div class="settings-header">

    <button id="menuBtn" class="menu-btn">

        <i class="fa-solid fa-bars"></i>

    </button>
                <div>

                    <h1 class="page-heading">
                        Settings</h1>

                    <p class="page-subtitle">
                        Configure your panel preferences
                    </p>

                </div>

            </div>

            <div class="settings-search">

                <i class="fa-solid fa-magnifying-glass"></i>

                <input
                    type="text"
                    placeholder="Search settings...">

            </div>

            
            <div class="empty-search" style="display:none;">
                
                <i class="fa-solid fa-magnifying-glass"></i>
                
                <h3>No Settings Found</h3>
                
                <p>Try another keyword.</p>
                
            </div>
            
            <div class="settings-grid">

                <a href="/settings/account" class="setting-item">

                    <div class="setting-icon purple">

                        <i class="fa-solid fa-user"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Account</h3>

                        <p>Manage account details</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/security" class="setting-item">

                    <div class="setting-icon green">

                        <i class="fa-solid fa-shield-halved"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Security</h3>

                        <p>Security & login settings</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/license" class="setting-item">

                    <div class="setting-icon yellow">

                        <i class="fa-solid fa-key"></i>

                    </div>

                    <div class="setting-info">

                        <h3>License</h3>

                        <p>License configuration</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/api" class="setting-item">

                    <div class="setting-icon blue">

                        <i class="fa-solid fa-server"></i>

                    </div>

                    <div class="setting-info">

                        <h3>API</h3>

                        <p>API configuration</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/database" class="setting-item">

                    <div class="setting-icon violet">

                        <i class="fa-solid fa-database"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Database</h3>

                        <p>Database & backups</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/logs" class="setting-item">

                    <div class="setting-icon orange">

                        <i class="fa-solid fa-file-lines"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Logs</h3>

                        <p>Activity logs</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/appearance" class="setting-item">

                    <div class="setting-icon pink">

                        <i class="fa-solid fa-palette"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Appearance</h3>

                        <p>Theme & colors</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/notifications" class="setting-item">

                    <div class="setting-icon cyan">

                        <i class="fa-solid fa-bell"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Notifications</h3>

                        <p>Alerts & notifications</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/about" class="setting-item">

                    <div class="setting-icon indigo">

                        <i class="fa-solid fa-circle-info"></i>

                    </div>

                    <div class="setting-info">

                        <h3>About</h3>

                        <p>System information</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

            </div>

            <div class="system-status">

                <h3>

                    <i class="fa-solid fa-circle-check"></i>

                    System Status

                </h3>

                <div class="status-grid">

                    <div>

                        <span>Active Keys</span>

                        <strong>1256</strong>

                    </div>

                    <div>

                        <span>Expired Keys</span>

                        <strong>231</strong>

                    </div>

                    <div>

                        <span>Total Keys</span>

                        <strong>1487</strong>

                    </div>

                    <div>

                        <span>Online Users</span>

                        <strong>42</strong>

                    </div>

                </div>

            </div>

        </section>

    </main>

</div>

<script src="/js/utils.js"></script>
<script src="/js/settings.js"></script>

</body>

</html>