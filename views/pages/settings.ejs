<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>Settings | Game Panel</title>

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/settings.css">

        
        <%- include("../partials/head") %>
    </head>

<body>

<div class="dashboard-container">

    <!-- Sidebar -->
    <%- include("../partials/sidebar") %>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Topbar -->
        <%- include("../partials/topbar") %>

        <!-- Settings Content -->

        <section class="settings-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-user"></i>

                    Account

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>

                        Username

                    </label>

                    <div>

                        <input
                            type="text"
                            value="<%= admin.username %>"
                            readonly>

                        <button>

                            Change

                        </button>

                    </div>

                </div>

                <div class="setting-row">

                    <label>

                        Password

                    </label>

                    <div>

                        <input
                            type="password"
                            value="********"
                            readonly>

                        <button>

                            Change

                        </button>

                    </div>

                </div>

                <div class="setting-row">

                    <label>

                        Email

                    </label>

                    <div>

                        <input
                            type="email"
                            placeholder="Coming Soon"
                            disabled>

                    </div>

                </div>

                <div class="setting-row">

                    <label>

                        Logout All Sessions

                    </label>

                    <button
                        class="danger">

                        Logout

                    </button>

                </div>

            </div>

        </section>

        <!-- Security -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-shield-halved"></i>

                    Security

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>

                        Cloudflare Turnstile

                    </label>

                    <label class="switch">

                        <input
                            type="checkbox"
                            checked>

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>

                        Session Timeout

                    </label>

                    <select>

                        <option>15 Minutes</option>

                        <option>30 Minutes</option>

                        <option>1 Hour</option>

                        <option>Never</option>

                    </select>

                </div>

                <div class="setting-row">

                    <label>

                        Login Lock Rules

                    </label>

                    <button>

                        Configure

                    </button>

                </div>

                <div class="setting-row">

                    <label>

                        Force Single Login

                    </label>

                    <label class="switch">

                        <input
                            type="checkbox">

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>

                        JWT Expiry

                    </label>

                    <select>

                        <option>15 Minutes</option>

                        <option>30 Minutes</option>

                        <option>1 Hour</option>

                    </select>

                </div>

            </div>

        </section>

        <!-- License -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-key"></i>

                    License

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Default Public Expiry</label>

                    <input type="number" value="30">

                </div>

                <div class="setting-row">

                    <label>Default Premium Expiry</label>

                    <input type="number" value="30">

                </div>

                <div class="setting-row">

                    <label>Default Max Devices</label>

                    <input type="number" value="1">

                </div>

                <div class="setting-row">

                    <label>Public Prefix</label>

                    <input type="text" value="PUB-">

                </div>

                <div class="setting-row">

                    <label>Premium Prefix</label>

                    <input type="text" value="PREM-">

                </div>

                <div class="setting-row">

                    <label>Key Length</label>

                    <input type="number" value="16">

                </div>

                <div class="setting-row">

                    <label>Auto Uppercase</label>

                    <label class="switch">

                        <input type="checkbox" checked>

                        <span class="slider"></span>

                    </label>

                </div>

            </div>

        </section>

        <!-- API -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-server"></i>

                    API

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Public API</label>

                    <label class="switch">

                        <input type="checkbox" checked>

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>Premium API</label>

                    <label class="switch">

                        <input type="checkbox" checked>

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>Maintenance Mode</label>

                    <label class="switch">

                        <input type="checkbox">

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>Rate Limit</label>

                    <input type="number" value="100">

                </div>

            </div>

        </section>

        <!-- Database -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-database"></i>

                    Database

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Status</label>

                    <span class="status online">

                        Connected

                    </span>

                </div>

                <div class="setting-row">

                    <button>

                        Backup Database

                    </button>

                </div>

                <div class="setting-row">

                    <button>

                        Restore Backup

                    </button>

                </div>

                <div class="setting-row">

                    <button class="danger">

                        Clear Cache

                    </button>

                </div>

            </div>

        </section>

        <!-- Logs -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-clipboard-list"></i>

                    Logs

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Retention</label>

                    <select>

                        <option>7 Days</option>

                        <option selected>30 Days</option>

                        <option>90 Days</option>

                    </select>

                </div>

                <div class="setting-row">

                    <button>

                        Export Logs

                    </button>

                </div>

                <div class="setting-row">

                    <button class="danger">

                        Clear Logs

                    </button>

                </div>

            </div>

        </section>

        <!-- Appearance -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-palette"></i>

                    Appearance

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Dark Mode</label>

                    <label class="switch">

                        <input type="checkbox" checked>

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>Accent Color</label>

                    <select>

                        <option>Blue</option>

                        <option>Green</option>

                        <option>Purple</option>

                    </select>

                </div>

                <div class="setting-row">

                    <label>Sidebar Collapse</label>

                    <label class="switch">

                        <input type="checkbox">

                        <span class="slider"></span>

                    </label>

                </div>

            </div>

        </section>

        <!-- Notifications -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-bell"></i>

                    Notifications

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Telegram Alerts</label>

                    <label class="switch">

                        <input type="checkbox">

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>Discord Webhook</label>

                    <label class="switch">

                        <input type="checkbox">

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="setting-row">

                    <label>Email Alerts</label>

                    <label class="switch">

                        <input type="checkbox">

                        <span class="slider"></span>

                    </label>

                </div>

            </div>

        </section>

        <!-- About -->

        <section class="setting-card">

            <div class="card-header">

                <h2>

                    <i class="fa-solid fa-circle-info"></i>

                    About

                </h2>

                <i class="fa-solid fa-chevron-down toggle"></i>

            </div>

            <div class="card-body">

                <div class="setting-row">

                    <label>Panel Version</label>

                    <span>v1.0.0</span>

                </div>

                <div class="setting-row">

                    <label>Node.js</label>

                    <span>v22.x</span>

                </div>

                <div class="setting-row">

                    <label>MongoDB</label>

                    <span class="status online">

                        Connected

                    </span>

                </div>

                <div class="setting-row">

                    <label>Server Uptime</label>

                    <span>Loading...</span>

                </div>

            </div>

        </section>

    </main>

</div>

<script src="/js/settings.js"></script>

</body>
</html>