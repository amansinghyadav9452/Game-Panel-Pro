<!DOCTYPE html>
<html lang="en">

<head>

    <title>Game Panel | Settings</title>

    <%- include("../partials/head") %>

    <link rel="stylesheet" href="/css/settings.css">

</head>

<body>

<div id="overlay"></div>

<div class="layout">

    <%- include("../partials/sidebar") %>

    <main class="content">

        <section class="settings-page">

            <div class="settings-header">

    <button id="menuBtn" class="menu-btn">

        <i class="fa-solid fa-bars"></i>

    </button>
                <div>

                    <h1 class="page-heading">
                        Settings</h1>

                    <p class="page-subtitle">
                        Configure your panel preferences
                    </p>

                </div>

            </div>

            <div class="settings-search">

                <i class="fa-solid fa-magnifying-glass"></i>

                <input
                    type="text"
                    placeholder="Search settings...">

            </div>

            
            <div class="empty-search" style="display:none;">
                
                <i class="fa-solid fa-magnifying-glass"></i>
                
                <h3>No Settings Found</h3>
                
                <p>Try another keyword.</p>
                
            </div>
            
            <div class="settings-grid">

                <a href="/settings/account" class="setting-item">

                    <div class="setting-icon purple">

                        <i class="fa-solid fa-user"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Account</h3>

                        <p>Manage account details</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/security" class="setting-item">

                    <div class="setting-icon green">

                        <i class="fa-solid fa-shield-halved"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Security</h3>

                        <p>Security & login settings</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/license" class="setting-item">

                    <div class="setting-icon yellow">

                        <i class="fa-solid fa-key"></i>

                    </div>

                    <div class="setting-info">

                        <h3>License</h3>

                        <p>License configuration</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/api" class="setting-item">

                    <div class="setting-icon blue">

                        <i class="fa-solid fa-server"></i>

                    </div>

                    <div class="setting-info">

                        <h3>API</h3>

                        <p>API configuration</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/database" class="setting-item">

                    <div class="setting-icon violet">

                        <i class="fa-solid fa-database"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Database</h3>

                        <p>Database & backups</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/logs" class="setting-item">

                    <div class="setting-icon orange">

                        <i class="fa-solid fa-file-lines"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Logs</h3>

                        <p>Activity logs</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/appearance" class="setting-item">

                    <div class="setting-icon pink">

                        <i class="fa-solid fa-palette"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Appearance</h3>

                        <p>Theme & colors</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/notifications" class="setting-item">

                    <div class="setting-icon cyan">

                        <i class="fa-solid fa-bell"></i>

                    </div>

                    <div class="setting-info">

                        <h3>Notifications</h3>

                        <p>Alerts & notifications</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

                <a href="/settings/about" class="setting-item">

                    <div class="setting-icon indigo">

                        <i class="fa-solid fa-circle-info"></i>

                    </div>

                    <div class="setting-info">

                        <h3>About</h3>

                        <p>System information</p>

                    </div>

                    <i class="fa-solid fa-chevron-right"></i>

                </a>

            </div>

            <div class="system-status">

                <h3>

                    <i class="fa-solid fa-circle-check"></i>

                    Security & Protection
                      
                </h3>

                <div class="status-grid">

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-key"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>JWT Authentication</span>

            <span class="badge active">

                Active

            </span>

        </div>

        <small>

            Secure login tokens enabled

        </small>

    </div>

</div>

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-lock"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>Password Hashing</span>

            <span class="badge active">
                bcrypt
            </span>

        </div>

        <small>12 Salt Rounds</small>

    </div>

</div>                  
<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-globe"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>HTTPS / SSL</span>

            <span class="badge active">
                Enabled
            </span>

        </div>

        <small>Encrypted HTTPS connection</small>

    </div>

</div>

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-shield-halved"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>Helmet Security</span>

            <span class="badge active">
                Enabled
            </span>

        </div>

        <small>Security headers applied</small>

    </div>

</div>

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-gauge-high"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>Rate Limiter</span>

            <span class="badge active">
                Active
            </span>

        </div>

        <small>100 requests / 15 minutes</small>

    </div>

</div>

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-earth-asia"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>CORS Policy</span>

            <span class="badge active">
                Restricted
            </span>

        </div>

        <small>Allowed origins only</small>

    </div>

</div>

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-file-lines"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>Security Headers</span>

            <span class="badge active">
                Applied
            </span>

        </div>

        <small>CSP, HSTS & XSS Protection</small>

    </div>

</div>

<div class="status-card">

    <div class="status-icon">

        <i class="fa-solid fa-server"></i>

    </div>

    <div class="status-content">

        <div class="status-top">

            <span>Environment</span>

            <span class="badge warning">
                Development
            </span>

        </div>

        <small>Production mode recommended</small>

    </div>

</div>

                </div>

            </div>

        </section>

    </main>

</div>

<script src="/js/utils.js"></script>
<script src="/js/settings.js"></script>

</body>

</html>