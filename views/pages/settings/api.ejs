<!DOCTYPE html>
<html lang="en">

<head>

<title>Game Panel | API</title>

<%- include("../../partials/head") %>

<link rel="stylesheet" href="/css/security-settings.css">

</head>

<body>

<div id="overlay"></div>

<%- include("../../partials/toast") %>
<%- include("../../partials/confirm-modal") %>

<div class="layout">

<%- include("../../partials/sidebar") %>

<main class="content">

<section class="settings-page">

<div class="settings-header">

<a href="/settings" class="back-btn">

<i class="fa-solid fa-arrow-left"></i>

</a>

<div>

<h1 class="page-heading">
API
</h1>

<p class="page-subtitle">
Configure API behaviour
</p>

</div>

</div>

<div class="account-card">

<div class="setting-group">

<label>Public API</label>

<select id="publicApiEnabled">

<option value="true"
<%= settings.api.publicApiEnabled ? "selected" : "" %>>

Enabled

</option>

<option value="false"
<%= !settings.api.publicApiEnabled ? "selected" : "" %>>

Disabled

</option>

</select>

</div>

<div class="setting-group">

<label>Premium API</label>

<select id="premiumApiEnabled">

<option value="true"
<%= settings.api.premiumApiEnabled ? "selected" : "" %>>

Enabled

</option>

<option value="false"
<%= !settings.api.premiumApiEnabled ? "selected" : "" %>>

Disabled

</option>

</select>

</div>

<div class="setting-group">

<label>Maintenance Mode</label>

<select id="maintenanceMode">

<option value="false"
<%= !settings.api.maintenanceMode ? "selected" : "" %>>

Disabled

</option>

<option value="true"
<%= settings.api.maintenanceMode ? "selected" : "" %>>

Enabled

</option>

</select>

</div>

<div class="setting-group">

<label>Requests Per Minute</label>

<input
id="rateLimit"
type="number"
value="<%= settings.api.rateLimit %>">

</div>

<div class="setting-group">

<label>API Version</label>

<input
id="apiVersion"
type="text"
value="<%= settings.api.version %>"
readonly>

</div>

<button id="saveApiBtn" class="save-btn">

<i class="fa-solid fa-floppy-disk"></i>

Save Changes

</button>

</div>

</section>

</main>

</div>

<script src="/js/utils.js"></script>
<script src="/js/api-settings.js"></script>

</body>

</html>