<!DOCTYPE html>
<html lang="en">

<head>

<title>Game Panel | Security</title>

<%- include("../../partials/head") %>

<link rel="stylesheet" href="/css/security-settings.css">

</head>

<body>

<div id="overlay"></div>

<%- include("../../partials/toast") %>
<%- include("../../partials/confirm-modal") %>

<div class="layout">  

<%- include("../../partials/sidebar") %>

<main class="content">

<section class="settings-page">

<div class="settings-header">

<a href="/settings" class="back-btn">

<i class="fa-solid fa-arrow-left"></i>

</a>

<div>

<h1 class="page-heading">
Security
</h1>

<p class="page-subtitle">
Manage your security settings
</p>

</div>

</div>

<div class="account-card">

<div class="setting-group">

    <label>Biometric Login</label>

    <div class="setting-description">

        Secure your account using Fingerprint, Face ID or Windows Hello.

    </div>

    <div class="biometric-status">

        <span class="badge warning">

            Disabled

        </span>

    </div>

    <button
        id="enableBiometricBtn"
        type="button"
        class="save-btn">

        <i class="fa-solid fa-fingerprint"></i>

        Enable Biometric

    </button>

</div>

<div class="setting-group">

<label>Cloudflare Turnstile</label>

<select id="turnstileEnabled">

<option
value="true"
<%= settings.security.turnstileEnabled ? "selected" : "" %>>

Enabled

</option>

<option
value="false"
<%= !settings.security.turnstileEnabled ? "selected" : "" %>>

Disabled

</option>

</select>

</div>

<div class="setting-group">

<label>Force Single Login</label>

<select id="forceSingleLogin">

<option
value="true"
<%= settings.security.forceSingleLogin ? "selected" : "" %>>

Enabled

</option>

<option
value="false"
<%= !settings.security.forceSingleLogin ? "selected" : "" %>>

Disabled

</option>

</select>

</div>

<div class="setting-group">

<label>Session Timeout</label>

<select id="sessionTimeout">

<option
value="15"
<%= settings.security.sessionTimeout == 15 ? "selected" : "" %>>

15 Minutes

</option>

<option
value="30"
<%= settings.security.sessionTimeout == 30 ? "selected" : "" %>>

30 Minutes

</option>

<option
value="60"
<%= settings.security.sessionTimeout == 60 ? "selected" : "" %>>

1 Hour

</option>

</select>

</div>

<div class="setting-group">

<label>JWT Expiry</label>

<select id="jwtExpiry">

<option
value="1h"
<%= settings.security.jwtExpiry === "1h" ? "selected" : "" %>>

1 Hour

</option>

<option
value="6h"
<%= settings.security.jwtExpiry === "6h" ? "selected" : "" %>>

6 Hours

</option>

<option
value="24h"
<%= settings.security.jwtExpiry === "24h" ? "selected" : "" %>>

24 Hours

</option>

</select>

</div>

<div class="setting-group">

<label>Rate Limit</label>

<input
id="rateLimit"
type="number"
value="<%= settings.api.rateLimit %>">

</div>

<button
    id="saveSecurityBtn"
    class="save-btn">

<i class="fa-solid fa-floppy-disk"></i>

Save Changes

</button>

</div>

</section>

</main>

</div>

<script src="/js/utils.js"></script>

<script src="/vendor/simplewebauthn.js"></script>

<script src="/js/security-settings.js"></script>

</body>
</html>