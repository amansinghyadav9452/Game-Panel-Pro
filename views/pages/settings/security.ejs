<!DOCTYPE html>
<html lang="en">

<head>

<title>Game Panel | Security</title>

<%- include("../../partials/head") %>

<link rel="stylesheet" href="/css/security-settings.css">

</head>

<body>

<div id="overlay"></div>

<div class="layout">

<%- include("../../partials/sidebar") %>

<main class="content">

<section class="settings-page">

<div class="settings-header">

<a href="/settings" class="back-btn">

<i class="fa-solid fa-arrow-left"></i>

</a>

<div>

<h1 class="page-heading">
Security
</h1>

<p class="page-subtitle">
Manage your security settings
</p>

</div>

</div>

<div class="account-card">

<div class="setting-group">

<label>Cloudflare Turnstile</label>

<select>

<option>Enabled</option>

<option>Disabled</option>

</select>

</div>

<div class="setting-group">

<label>Force Single Login</label>

<select>

<option>Enabled</option>

<option>Disabled</option>

</select>

</div>

<div class="setting-group">

<label>Session Timeout</label>

<select>

<option>15 Minutes</option>

<option>30 Minutes</option>

<option>1 Hour</option>

</select>

</div>

<div class="setting-group">

<label>JWT Expiry</label>

<select>

<option>1 Hour</option>

<option>6 Hours</option>

<option>24 Hours</option>

</select>

</div>

<div class="setting-group">

<label>Rate Limit</label>

<input
type="number"
value="100">

</div>

<button
class="save-btn">

<i class="fa-solid fa-floppy-disk"></i>

Save Changes

</button>

</div>

</section>

</main>

</div>

<script src="/js/utils.js"></script>
<script src="/js/security-settings.js"></script>

</body>
</html>