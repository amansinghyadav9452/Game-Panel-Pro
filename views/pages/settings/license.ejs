<!DOCTYPE html>
<html lang="en">

<head>

<title>Game Panel | License</title>

<%- include("../../partials/head") %>

<link rel="stylesheet" href="/css/security-settings.css">

</head>

<body>

<div id="overlay"></div>

<%- include("../../partials/toast") %>
<%- include("../../partials/confirm-modal") %>

<div class="layout">

<%- include("../../partials/sidebar") %>

<main class="content">

<section class="settings-page">

<div class="settings-header">

<a href="/settings" class="back-btn">

<i class="fa-solid fa-arrow-left"></i>

</a>

<div>

<h1 class="page-heading">
License
</h1>

<p class="page-subtitle">
Configure license generation settings
</p>

</div>

</div>

<div class="account-card">

<div class="setting-group">

<label>Public Key Prefix</label>

<input
id="publicPrefix"
type="text"
value="<%= settings.license.publicPrefix %>">

</div>

<div class="setting-group">

<label>Premium Key Prefix</label>

<input
id="premiumPrefix"
type="text"
value="<%= settings.license.premiumPrefix %>">

</div>

<div class="setting-group">

<div class="setting-group">

<label>Public Default Expiry (Days)</label>

<input
id="publicExpiry"
type="number"
value="<%= settings.license.publicExpiry %>">

</div>

<div class="setting-group">

<div class="setting-group">

<label>Public Default Expiry (Days)</label>

<input
id="publicExpiry"
type="number"
value="<%= settings.license.publicExpiry %>">

</div>

<div class="setting-group">

<label>Premium Default Expiry (Days)</label>

<input
id="premiumExpiry"
type="number"
value="<%= settings.license.premiumExpiry %>">

</div>

</div>

</div>

<div class="setting-group">

<label>Maximum Devices</label>

<input
id="maxDevices"
type="number"
value="<%= settings.license.maxDevices %>">

</div>

<div class="setting-group">

<label>License Length</label>

<input
id="licenseLength"
type="number"
value="<%= settings.license.licenseLength %>">

</div>

<div class="setting-group">

<label>Auto Uppercase</label>

<select id="autoUppercase">

<option
value="true"
<%= settings.license.autoUppercase ? "selected" : "" %>>

Enabled

</option>

<option
value="false"
<%= !settings.license.autoUppercase ? "selected" : "" %>>

Disabled

</option>

</select>

</div>

<button id="saveLicenseBtn" class="save-btn">

<i class="fa-solid fa-floppy-disk"></i>

Save Changes

</button>

</div>

</section>

</main>

</div>

<script src="/js/utils.js"></script>
<script src="/js/license-settings.js"></script>

</body>

</html>