<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Game Panel | Login</title>

    <!-- Google Font -->

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <!-- CSS -->

    <link rel="stylesheet" href="/css/login.css">

</head>

<body>

<div class="background">

    <span class="circle c1"></span>

    <span class="circle c2"></span>

    <span class="circle c3"></span>

    <div class="particles">

        <span></span>

        <span></span>

        <span></span>

        <span></span>

        <span></span>

        <span></span>

    </div>

</div>

    <main class="login-wrapper">

        <section class="login-card">

            <div class="mouse-light"></div>

            <div class="logo">

                <div class="logo-box">

                    <i class="fa-solid fa-shield-halved"></i>

                </div>

                <h1>GAME PANEL</h1>

                <p>Enterprise Security Management</p>

                <div class="security-status">

    <span>

        <i class="fa-solid fa-circle"></i>

        MongoDB

    </span>

    <span>

        <i class="fa-solid fa-circle"></i>

        JWT

    </span>

    <span>

        <i class="fa-solid fa-circle"></i>

        Cloudflare

    </span>

</div>

            </div>

            <form id="loginForm">

                <div class="input-group">

                    <label> Admin Username</label>

                    <div class="input-box">

                        <i class="fa-solid fa-user"></i>

                        <input
                            type="text"
                            id="username"
                            placeholder="Enter username"
                            autocomplete="off"
                            required>

                    </div>

                </div>

                <div class="input-group">

                    <label> Enter Secure Password</label>

                    <div class="input-box">

                        <i class="fa-solid fa-lock"></i>

                        <input
                            type="password"
                            id="password"
                            placeholder="Enter password"
                            required>

                        <button
                            type="button"
                            id="togglePassword">

                            <i class="fa-solid fa-eye"></i>

                        </button>

                    </div>

                </div>

                <div class="login-options">

                    <label>

                        <input type="checkbox">

                        Remember Me

                    </label>

                </div>
                    <div
    class="cf-turnstile"
    data-sitekey="0x4AAAAAADz59UgKdhvFUXRc">
    </div>

    <!-- Fingerprint Authentication -->

<div class="fingerprint-auth">

    <div class="fp-divider">
        <span>OR</span>
    </div>

    <button
        type="button"
        id="fingerprintLogin"
        class="fingerprint-btn">

        <div class="fp-circle">

            <i class="fas fa-fingerprint"></i>

        </div>

        <span class="fp-text">
            Touch to Authenticate
        </span>

    </button>

</div>

                <button
                    class="login-btn"
                    id="loginBtn"
                    type="submit">

                    <i class="fa-solid fa-arrow-right-to-bracket"></i>

                    Sign In

                </button>

                <button
    type="button"
    id="biometricLoginBtn"
    class="btn btn-secondary">

    <i class="fa-solid fa-fingerprint"></i>
    Touch to Authenticate

</button>

            </form>

            <div id="message"></div>

            <div class="footer">

    <p>

<i class="fa-solid fa-shield-check"></i>

Protected by Cloudflare Turnstile • JWT • MongoDB

</p>

            </div>

        </section>

    </main>

<script src="/vendor/simplewebauthn.js"></script>
<script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
<script src="/js/login.js"></script>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

</body>

</html>