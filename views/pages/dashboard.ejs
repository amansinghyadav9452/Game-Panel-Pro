<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Game Panel | Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="stylesheet" href="/css/dashboard.css">

</head>

<body>
    <div id="overlay"></div>
<div class="layout">

    <aside class="sidebar">

        <div class="logo">

            <i class="fa-solid fa-shield-halved"></i>

            <span>GAME PANEL</span>

        </div>

        <div class="admin-info">

    <div class="avatar">

        A

    </div>

    <div>

        <h4>Administrator</h4>

<small>

    <i class="fa-solid fa-circle"></i>

    Online

</small>

    </div>

</div>

        <nav>

            <a href="#" class="active">

                <i class="fa-solid fa-house"></i>

                Dashboard

            </a>

            <a href="#">

                <i class="fa-solid fa-key"></i>

                Public Keys

            </a>

            <a href="#">

                <i class="fa-solid fa-crown"></i>

                Premium Keys

            </a>

            <a href="#">

                <i class="fa-solid fa-clock-rotate-left"></i>

                Logs

            </a>

            <a href="#">

                <i class="fa-solid fa-gear"></i>

                Settings

            </a>

        </nav>

    </aside>

    <main class="content">

<header class="topbar">

    <div class="left-section">

        <button id="menuBtn">

            <i class="fa-solid fa-bars"></i>

        </button>

        <h2>Dashboard</h2>

    </div>

    <div class="right-section">

        <div class="search-box">

            <i class="fa-solid fa-magnifying-glass"></i>

            <input
                type="text"
                placeholder="Search License...">

        </div>

        <button class="icon-btn">

            <i class="fa-solid fa-bell"></i>

        </button>

        <button id="logoutBtn">

            <i class="fa-solid fa-right-from-bracket"></i>

            Logout

        </button>

    </div>

</header>

        <section class="cards">

            <div class="card">

                <h3>Total Keys</h3>

                <span id="totalKeys">0</span>
                <small>Live Data</small>
            </div>

            <div class="card">

                <h3>Active</h3>

                <span id="activeKeys">0</span>
                <small>Currently Active</small>
            </div>

            <div class="card">

                <h3>Expired</h3>

                <span id="expiredKeys">0</span>
                <small>Need Attention</small>

            </div>

            <div class="card">

                <h3>Banned</h3>

                <span id="bannedKeys">0</span>
                <small>Blocked Keys</small>
            </div>

        </section>

        <section class="table-section">

            <div class="table-header">

                <h2>Licenses</h2>

<button id="openCreateModal">

    + Create Key

</button>

            </div>

            <table>

                <thead>

                    <tr>

                        <th>Key</th>

                        <th>Status</th>

                        <th>Expiry</th>

                        <th>Devices</th>

                        <th>Action</th>

                    </tr>

                </thead>

                <tbody id="licenseTable">

                </tbody>

            </table>

        </section>

        <div id="licenseModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>License Details</h2>

            <button id="closeModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <div class="detail">

                <span>Key</span>

                <strong id="modalKey">-</strong>

            </div>

            <div class="detail">

                <span>Status</span>

                <strong id="modalStatus">-</strong>

            </div>

            <div class="detail">

                <span>Expiry</span>

                <strong id="modalExpiry">-</strong>

            </div>

            <div class="detail">

                <span>Devices</span>

                <strong id="modalDevices">-</strong>

            </div>

            <div class="detail">

                <span>Last Device</span>

                <strong id="modalLastDevice">-</strong>

            </div>

        </div>

        <div class="modal-actions">

<button
    class="ban-btn"
    id="banLicenseBtn">

    Ban

</button>

<button
    class="extend-btn"
    id="extendLicenseBtn">

    Extend

</button>

            <button class="reset-btn" id="resetDeviceBtn">

                Reset Device

            </button>

            <button
                class="delete-btn"
                id="deleteLicenseBtn">

                Delete

            </button>
        </div>

    </div>

</div>

<div id="createKeyModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>Create License</h2>

            <button id="closeCreateModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <div class="input-group">

    <label>License Key</label>

    <input
        type="text"
        id="licenseKey"
        placeholder="Enter License Key"
        maxlength="32"
        minlength="4"
        autocomplete="off"
        required>

</div>

            <div class="input-group">

                <label>License Type</label>

                <select id="licenseType">

                    <option value="public">Public</option>

                    <option value="premium">Premium</option>

                </select>

            </div>

            <div class="input-group">

                <label>Expiry (Days)</label>

                <input
                    type="number"
                    id="expiryDays"
                    value="30">

            </div>

            <div class="input-group">

                <label>Max Devices</label>

                <input
                    type="number"
                    id="maxUses"
                    value="1">

            </div>

        </div>

        <div class="modal-actions">

            <button id="generateBtn">

                Generate License

            </button>

        </div>

    </div>

</div>

        <div id="deleteModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>Delete License</h2>

            <button id="closeDeleteModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <p style="text-align:center;font-size:17px;line-height:1.6;">

                Are you sure you want to delete this license?

                <br><br>

                <strong id="deleteLicenseKey"></strong>

            </p>

        </div>

        <div class="modal-actions">

            <button
                class="reset-btn"
                id="cancelDeleteBtn">

                Cancel

            </button>

            <button
                class="delete-btn"
                id="confirmDeleteBtn">

                Delete Forever

            </button>

        </div>

    </div>

</div>

    </main>

</div>
<div id="toast"></div>
<div id="extendModal" class="modal">

    <div class="modal-content">

        <div class="modal-header">

            <h2>Extend License</h2>

            <button id="closeExtendModal">

                <i class="fa-solid fa-xmark"></i>

            </button>

        </div>

        <div class="modal-body">

            <div class="input-group">

                <label>Extend Days</label>

                <input
                    type="number"
                    id="extendDays"
                    value="30"
                    min="1">

            </div>

        </div>

        <div class="modal-actions">

            <button id="saveExtendBtn">

                Extend License

            </button>

        </div>

    </div>

</div>
<script src="/js/dashboard.js"></script>

</body>

</html>