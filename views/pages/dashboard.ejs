<!DOCTYPE html>
<html lang="en">

<head>

<title>Game Panel | Dashboard</title>

<%- include("../partials/head") %>

</head>

<body>
    <div id="overlay"></div>
<div class="layout">

    <%- include("../partials/sidebar") %>

    <main class="content">

<%- include("../partials/topbar") %>

        <section class="cards">

            <div class="card">

                <h3>Total Keys</h3>

                <span id="totalKeys">0</span>
                <small>Live Data</small>
            </div>

            <div class="card">

                <h3>Active</h3>

                <span id="activeKeys">0</span>
                <small>Currently Active</small>
            </div>

            <div class="card">

                <h3>Expired</h3>

                <span id="expiredKeys">0</span>
                <small>Need Attention</small>

            </div>

            <div class="card">

                <h3>Banned</h3>

                <span id="bannedKeys">0</span>
                <small>Blocked Keys</small>
            </div>

        </section>

<section class="overview-section">

    <h2>Recent Activity</h2>

    <div id="recentActivityList">

        <p style="color:#94A3B8; margin-top:12px;">

            Loading...

        </p>

    </div>

</section>

<%- include("../partials/modals") %>

<script src="/js/api.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/license-manager.js"></script>
<script src="/js/dashboard.js"></script>

</body>

</html>